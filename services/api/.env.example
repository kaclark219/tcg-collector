# Copy this file to services/api/.env and fill in your real values.
# This file is safe to commit. The real .env is ignored by git.

# Preferred: direct Postgres connection string for your Supabase project.
DATABASE_URL=postgresql://postgres:<your-db-password>@db.<your-project-ref>.supabase.co:5432/postgres

# Optional fallback if you prefer this variable name instead.
# SUPABASE_DB_URL=postgresql://postgres:<your-db-password>@db.<your-project-ref>.supabase.co:5432/postgres

# Optional metadata that may be useful later.
# SUPABASE_PROJECT_REF=your-project-ref

